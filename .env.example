# Copy to .env and adjust. Never commit .env.

DJANGO_SECRET_KEY=change-me-in-production
DJANGO_SETTINGS_MODULE=core.settings.development
DEBUG=True

# Comma-separated hosts in production (e.g. localhost,127.0.0.1,your-domain.com)
ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL via Docker Compose: postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# Fallback when DATABASE_URL is empty (SQLite for quick local tries)
USE_SQLITE_IF_NO_DATABASE_URL=true

# CORS origins (comma-separated). Include the Vite dev server when using frontend/ (port 5173).
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://127.0.0.1:5173,http://localhost:5173

# Absolute base URL used in outbound emails for verification/password links
PUBLIC_SITE_ORIGIN=http://127.0.0.1:8000

# Email (smtp); leave blank in dev to use console backend automatically
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=webmaster@localhost
